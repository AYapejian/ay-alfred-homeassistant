root = true

# =============================================================================
# Default: all files
# =============================================================================
[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

# =============================================================================
# Web / Config formats (YAML is critical for Home Assistant)
# =============================================================================
[*.{js,ts,jsx,tsx,json,css,scss,html}]
indent_style = space
indent_size = 2

[*.{yml,yaml}]
indent_style = space
indent_size = 2

# =============================================================================
# Python
# =============================================================================
[*.py]
indent_style = space
indent_size = 4
max_line_length = 88

# =============================================================================
# Shell scripts
# =============================================================================
[*.{sh,bash,zsh}]
indent_style = space
indent_size = 2

# =============================================================================
# Makefiles (tabs required)
# =============================================================================
[Makefile]
indent_style = tab

# =============================================================================
# Markdown (preserve trailing spaces — they render as <br>)
# =============================================================================
[*.{md,mdx}]
trim_trailing_whitespace = false
indent_style = space
indent_size = 2

# =============================================================================
# Docker
# =============================================================================
[Dockerfile*]
indent_style = space
indent_size = 4

# =============================================================================
# TOML
# =============================================================================
[*.toml]
indent_style = space
indent_size = 2
